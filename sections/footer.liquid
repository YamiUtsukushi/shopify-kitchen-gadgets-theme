{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ===== FOOTER GLOBAL ===== */
  .custom-footer-{{ section.id }} {
    background-color: #1e1e1e;
    color: #ffffff;
  }

  /* ===== CORPS — 4 COLONNES ===== */
  .custom-footer-{{ section.id }} .footer-body {
    padding: 30px 0 20px;
  }

  .custom-footer-{{ section.id }} .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  @media screen and (max-width: 989px) {
    .custom-footer-{{ section.id }} .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .custom-footer-{{ section.id }} .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.8rem;
    }
    .custom-footer-{{ section.id }} .footer-body {
      padding: 40px 0 28px;
    }
  }

  /* --- Col 1 Branding --- */
  .custom-footer-{{ section.id }} .footer-brand__logo img {
    max-width: 140px;
    height: auto;
    margin-bottom: 1rem;
  }

  .custom-footer-{{ section.id }} .footer-brand__mission {
    font-size: 1.5rem;
    line-height: 1.7;
    color: #b0b0b0;
    margin: 0 0 1.4rem 0;
    max-width: 280px;
  }

  /* --- Col 2 & 3 Menus --- */
  .custom-footer-{{ section.id }} .footer-col__heading {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 1.2rem 0;
  }

  .custom-footer-{{ section.id }} .footer-col__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .custom-footer-{{ section.id }} .footer-col__list a {
    font-size: 1.3rem;
    color: #b0b0b0;
    text-decoration: none;
    transition: color 0.2s;
  }
  .custom-footer-{{ section.id }} .footer-col__list a:hover {
    color: #36881f;
  }

  /* Badge SALE */
  .custom-footer-{{ section.id }} .footer-badge-sale {
    display: inline-block;
    background-color: #36881f;
    color: #ffffff;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1px 6px;
    border-radius: 3px;
    margin-left: 6px;
    vertical-align: middle;
    text-transform: uppercase;
  }

  /* --- Col 4 Aide --- */
  .custom-footer-{{ section.id }} .footer-aide__icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    display: block;
    line-height: 1;
  }

  .custom-footer-{{ section.id }} .footer-aide__question {
    font-size: 0.92rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  .custom-footer-{{ section.id }} .footer-aide__cta {
    display: inline-block;
    background-color: #36881f;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.55rem 1.2rem;
    border-radius: 4px;
    transition: background-color 0.2s;
  }
  .custom-footer-{{ section.id }} .footer-aide__cta:hover {
    background-color: #5a9228;
  }

  /* ===== BOTTOM BAR ===== */
  .custom-footer-{{ section.id }} .footer-bottom {
    margin-top: 0;
    padding: 1rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .custom-footer-{{ section.id }} .footer-bottom__payments {
    padding: 1rem 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
  }
  .custom-footer-{{ section.id }} .footer-bottom__payments .icon--full-color {
    width: 36px;
    height: 22px;
  }

  .custom-footer-{{ section.id }} .footer-bottom__copy {
    font-size: 0.82rem;
    color: #888888;
    margin: 0;
  }
  .custom-footer-{{ section.id }} .footer-bottom__copy a {
    color: #888888;
    text-decoration: none;
  }

  .custom-footer-{{ section.id }} .footer-bottom__socials {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .custom-footer-{{ section.id }} .footer-bottom__socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #2e2e2e;
    color: #cccccc;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }
  .custom-footer-{{ section.id }} .footer-bottom__socials a:hover {
    background: #36881f;
    color: #ffffff;
  }
  .custom-footer-{{ section.id }} .footer-bottom__socials svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  @media screen and (max-width: 749px) {
    .custom-footer-{{ section.id }} .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{%- endstyle -%}

<footer class="custom-footer-{{ section.id }}" role="contentinfo">
  <div class="footer-body">
    <div class="page-width">
      <div class="footer-grid">

        {%- comment -%} ===== COL 1 — BRANDING ===== {%- endcomment -%}
        <div class="footer-col footer-brand">
          {%- if section.settings.logo != blank -%}
            <div class="footer-brand__logo">
              <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
                {%- assign logo_height = section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round -%}
                {{
                  section.settings.logo
                  | image_url: width: 280
                  | image_tag:
                    loading: 'lazy',
                    alt: shop.name,
                    width: section.settings.logo_width,
                    height: logo_height
                }}
              </a>
            </div>
          {%- else -%}
            <p style="font-size:2rem;font-weight:800;color:#ffffff;margin:0 0 1rem 0;">{{ shop.name }}</p>
          {%- endif -%}

          <p class="footer-brand__mission">{{ section.settings.mission_text }}</p>
        </div>

        {%- comment -%} ===== COL 2 — BOUTIQUE ===== {%- endcomment -%}
        <div class="footer-col">
          <h3 class="footer-col__heading">{{ section.settings.col2_heading }}</h3>
          {%- if section.settings.col2_menu != blank -%}
            <ul class="footer-col__list" role="list">
              {%- for link in section.settings.col2_menu.links -%}
                <li>
                  <a href="{{ link.url }}">
                    {{ link.title | escape }}
                    {%- if link.title contains 'Nouveauté' or link.title contains 'nouveauté' -%}
                      <span class="footer-badge-sale">SALE</span>
                    {%- endif -%}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- comment -%} ===== COL 3 — INFOS ===== {%- endcomment -%}
        <div class="footer-col">
          <h3 class="footer-col__heading">{{ section.settings.col3_heading }}</h3>
          {%- if section.settings.col3_menu != blank -%}
            <ul class="footer-col__list" role="list">
              {%- for link in section.settings.col3_menu.links -%}
                <li>
                  <a href="{{ link.url }}">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- comment -%} ===== COL 4 — AIDE ===== {%- endcomment -%}
        <div class="footer-col">
          <h3 class="footer-col__heading">{{ section.settings.col4_heading }}</h3>
          <span class="footer-aide__icon" aria-hidden="true">{{ section.settings.aide_icon }}</span>
          <p class="footer-aide__question">{{ section.settings.aide_question }}</p>
          {%- if section.settings.aide_contact_url != blank -%}
            <a href="{{ section.settings.aide_contact_url }}" class="footer-aide__cta">
              {{ section.settings.aide_contact_label }}
            </a>
          {%- endif -%}
        </div>

      </div>{%- comment -%} /footer-grid {%- endcomment -%}
    </div>{%- comment -%} /page-width {%- endcomment -%}
  </div>{%- comment -%} /footer-body {%- endcomment -%}

  {%- comment -%} ===== BOTTOM BAR ===== {%- endcomment -%}
  <div class="page-width">

    {%- if section.settings.show_payments_row -%}
      <div class="footer-bottom__payments">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="footer-bottom">
      <p class="footer-bottom__copy">
        &copy; {{ 'now' | date: '%Y' }}, {{ section.settings.company_name }}.
        {{ section.settings.powered_by_text }}
        <a href="https://www.shopify.com" target="_blank" rel="noopener">Shopify</a>.
      </p>

      {%- comment -%} Icônes sociales {%- endcomment -%}
      <div class="footer-bottom__socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.79a8.18 8.18 0 004.79 1.53V6.87a4.85 4.85 0 01-1.02-.18z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>

</footer>

{% schema %}
{
  "name": "Footer personnalisé",
  "settings": [
    {
      "type": "header",
      "content": "Colonne 1 — Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Largeur du logo",
      "default": 120
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Texte mission",
      "default": "Notre mission : rendre la cuisine du quotidien plus simple, plus fun et plus accessible — avec des gadgets malins livrés chez vous en quelques jours."
    },
    {
      "type": "header",
      "content": "Colonne 2 — Boutique"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Titre colonne 2",
      "default": "BOUTIQUE"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Menu Boutique",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Colonne 3 — Infos"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Titre colonne 3",
      "default": "INFOS"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Menu Infos",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Colonne 4 — Aide"
    },
    {
      "type": "text",
      "id": "col4_heading",
      "label": "Titre colonne 4",
      "default": "AIDE"
    },
    {
      "type": "text",
      "id": "aide_icon",
      "label": "Icône (emoji)",
      "default": "🍳"
    },
    {
      "type": "text",
      "id": "aide_question",
      "label": "Question d'aide",
      "default": "Une question sur un produit ?"
    },
    {
      "type": "text",
      "id": "aide_contact_label",
      "label": "Texte du bouton contact",
      "default": "Contactez-nous"
    },
    {
      "type": "url",
      "id": "aide_contact_url",
      "label": "Lien du bouton contact"
    },
    {
      "type": "header",
      "content": "Icônes de paiement (bas de page)"
    },
    {
      "type": "checkbox",
      "id": "show_payments_row",
      "label": "Afficher la ligne d'icônes de paiement",
      "default": true
    },
    {
      "type": "header",
      "content": "Barre de bas de page"
    },
    {
      "type": "text",
      "id": "company_name",
      "label": "Nom de l'entreprise",
      "default": "LD Global CO"
    },
    {
      "type": "text",
      "id": "powered_by_text",
      "label": "Texte \"propulsé par\"",
      "default": "Commerce électronique propulsé par"
    },
    {
      "type": "header",
      "content": "Réseaux sociaux"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram (laisser vide pour masquer)"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok (laisser vide pour masquer)"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest (laisser vide pour masquer)"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook (laisser vide pour masquer)"
    }
  ]
}
{% endschema %}
