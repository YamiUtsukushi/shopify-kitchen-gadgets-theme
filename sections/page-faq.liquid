        { "type": "textarea", "id": "answer", "label": "Réponse", "default": "Votre réponse ici." }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ — LD Global",
      "blocks": [
        { "type": "category", "settings": { "name": "Commandes", "color": "#36881f" } },
        { "type": "faq_item", "settings": { "question": "Quels sont les moyens de paiement acceptés ?", "answer": "Nous acceptons les cartes bancaires (Visa, Mastercard, American Express), PayPal et Apple Pay. Tous les paiements sont 100 % sécurisés grâce au protocole SSL." } },
        { "type": "faq_item", "settings": { "question": "Quels sont les délais de traitement de ma commande ?", "answer": "Votre commande est traitée sous 1 à 2 jours ouvrés avant expédition. Vous recevrez un email de confirmation avec votre numéro de suivi." } },
        { "type": "faq_item", "settings": { "question": "Puis-je modifier ou annuler ma commande ?", "answer": "Vous pouvez modifier ou annuler votre commande dans les 24h suivant la validation. Passé ce délai, contactez-nous au plus vite via notre page Contact." } },
        { "type": "category", "settings": { "name": "Produits", "color": "#36881f" } },
        { "type": "faq_item", "settings": { "question": "À quoi servent vos produits de cuisine ?", "answer": "Nos accessoires sont conçus pour simplifier vos préparations : éplucheurs, spiraliseurs, minuteurs, outils de découpe, mixeurs et ustensiles pratiques pour cuisiner plus facilement et avec plus de plaisir." } },
        { "type": "faq_item", "settings": { "question": "Vos produits sont-ils faciles à utiliser au quotidien ?", "answer": "Oui, tous nos produits sont sélectionnés pour leur facilité d'utilisation et leur ergonomie. Ils sont pensés pour être pris en main rapidement, même sans expérience particulière." } },
        { "type": "faq_item", "settings": { "question": "Les matériaux utilisés sont-ils durables et résistants ?", "answer": "Nous sélectionnons des produits fabriqués avec des matériaux de qualité (acier inoxydable, ABS, silicone alimentaire). Chaque article est testé pour sa résistance et sa durabilité." } },
        { "type": "faq_item", "settings": { "question": "Comment entretenir mes ustensiles pour les garder efficaces ?", "answer": "La plupart de nos ustensiles se lavent facilement à l'eau chaude savonneuse ou au lave-vaisselle. Consultez la fiche produit pour les recommandations spécifiques à chaque article." } },
