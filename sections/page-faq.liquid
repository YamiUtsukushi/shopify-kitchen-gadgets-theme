{%- style -%}
  .page-faq-{{ section.id }} {
    font-family: 'Figtree', sans-serif;
  }

  /* ══ HERO ══ */
  .page-faq-{{ section.id }} .faq-hero {
    position: relative;
    height: 380px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: #2a2a2a;
  }
  .page-faq-{{ section.id }} .faq-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .page-faq-{{ section.id }} .faq-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
  }
  .page-faq-{{ section.id }} .faq-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 2rem;
  }
  .page-faq-{{ section.id }} .faq-hero__title {
    font-size: clamp(5rem, 12vw, 9rem);
    font-weight: 900;
    color: #ffffff;
    margin: 0 0 0.8rem;
    line-height: 1;
  }
  .page-faq-{{ section.id }} .faq-hero__subtitle {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: rgba(255, 255, 255, 0.88);
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    .page-faq-{{ section.id }} .faq-hero { height: 260px; }
  }

  /* ══ MAIN ══ */
  .page-faq-{{ section.id }} .faq-main {
    background-color: #f5f3ee;
    padding: 5rem 2rem;
  }
  .page-faq-{{ section.id }} .faq-main__inner {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }
  @media screen and (max-width: 989px) {
    .page-faq-{{ section.id }} .faq-main { padding: 3rem 1.5rem; }
    .page-faq-{{ section.id }} .faq-main__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* ══ SIDEBAR ══ */
  .page-faq-{{ section.id }} .faq-sidebar {
    position: sticky;
    top: 2rem;
  }
  @media screen and (max-width: 989px) {
    .page-faq-{{ section.id }} .faq-sidebar {
      position: static;
    }
  }
  .page-faq-{{ section.id }} .faq-sidebar__title {
    font-size: clamp(4.5rem, 9vw, 7rem);
    font-weight: 900;
    color: #1a1a1a;
    margin: 0 0 0.4rem;
    line-height: 1;
  }
  .page-faq-{{ section.id }} .faq-sidebar__icon {
    display: block;
    width: 52px;
    height: 52px;
    object-fit: contain;
    margin-bottom: 0.8rem;
  }
  .page-faq-{{ section.id }} .faq-sidebar__tagline {
    font-size: 2.3rem;
    font-weight: 800;
    color: #1a1a1a;
    line-height: 1.25;
    margin: 0 0 1.2rem;
  }
  .page-faq-{{ section.id }} .faq-sidebar__divider {
    width: 3rem;
    height: 3px;
    background-color: #36881f;
    border-radius: 2px;
    margin: 0 0 1.2rem;
  }
  .page-faq-{{ section.id }} .faq-sidebar__sub {
    font-size: 1.5rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  /* Search */
  .page-faq-{{ section.id }} .faq-search {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: #ffffff;
    border: 1.5px solid #ddd5c5;
    border-radius: 10px;
    padding: 0.9rem 1.2rem;
    margin-bottom: 2rem;
  }
  .page-faq-{{ section.id }} .faq-search__icon {
    color: #aaa;
    flex-shrink: 0;
    display: flex;
  }
  .page-faq-{{ section.id }} .faq-search__input {
    border: none;
    outline: none;
    background: transparent;
    font-size: 1.4rem;
    color: #333;
    font-family: inherit;
    width: 100%;
  }
  .page-faq-{{ section.id }} .faq-search__input::placeholder { color: #bbb; }

  /* Help */
  .page-faq-{{ section.id }} .faq-help {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .page-faq-{{ section.id }} .faq-help__icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .page-faq-{{ section.id }} .faq-help__label {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.25rem;
  }
  .page-faq-{{ section.id }} .faq-help__desc {
    font-size: 1.3rem;
    color: #666;
    margin: 0 0 0.4rem;
  }
  .page-faq-{{ section.id }} .faq-help__link {
    font-size: 1.3rem;
    color: #36881f;
    font-weight: 600;
    text-decoration: none;
  }
  .page-faq-{{ section.id }} .faq-help__link:hover { text-decoration: underline; }

  /* ══ PANEL ══ */
  .page-faq-{{ section.id }} .faq-panel {
    background: #ffffff;
    border-radius: 20px;
    padding: 2.5rem 3rem;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.07);
  }
  @media screen and (max-width: 749px) {
    .page-faq-{{ section.id }} .faq-panel { padding: 1.5rem; }
  }

  /* Category */
  .page-faq-{{ section.id }} .faq-cat { margin-bottom: 2rem; }
  .page-faq-{{ section.id }} .faq-cat:last-of-type { margin-bottom: 0; }
  .page-faq-{{ section.id }} .faq-cat__header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-bottom: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .page-faq-{{ section.id }} .faq-cat__icon {
    width: 50px;
    height: 50px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .page-faq-{{ section.id }} .faq-cat__name {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  /* Items */
  .page-faq-{{ section.id }} .faq-item {
    border-top: 1px solid #f0ebe0;
  }
  .page-faq-{{ section.id }} .faq-item:last-child {
    border-bottom: 1px solid #f0ebe0;
  }
  .page-faq-{{ section.id }} .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.4rem 0;
    cursor: pointer;
    list-style: none;
    font-size: 1.4rem;
    font-weight: 500;
    color: #1a1a1a;
  }
  .page-faq-{{ section.id }} .faq-item summary::-webkit-details-marker { display: none; }
  .page-faq-{{ section.id }} .faq-item summary::marker { display: none; }
  .page-faq-{{ section.id }} .faq-item__arrow {
    flex-shrink: 0;
    color: #aaa;
    display: flex;
    transition: transform 0.22s ease;
  }
  .page-faq-{{ section.id }} .faq-item[open] .faq-item__arrow {
    transform: rotate(180deg);
  }
  .page-faq-{{ section.id }} .faq-item__body {
    padding: 0 0 1.4rem;
    font-size: 1.35rem;
    color: #555;
    line-height: 1.75;
    animation: faq-fadein-{{ section.id }} 0.2s ease;
  }
  @keyframes faq-fadein-{{ section.id }} {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Panel footer */
  .page-faq-{{ section.id }} .faq-panel__footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f0ebe0;
    text-align: center;
    font-size: 1.35rem;
    color: #666;
  }
  .page-faq-{{ section.id }} .faq-panel__footer-link {
    color: #36881f;
    text-decoration: none;
    font-weight: 600;
  }
  .page-faq-{{ section.id }} .faq-panel__footer-link:hover { text-decoration: underline; }

  /* No results */
  .page-faq-{{ section.id }} .faq-no-results {
    display: none;
    text-align: center;
    padding: 2rem 1rem;
    font-size: 1.2rem;
    color: #999;
  }

  /* ══ CTA ══ */
  .page-faq-{{ section.id }} .faq-cta {
    padding: 4rem 2rem;
  }
  .page-faq-{{ section.id }} .faq-cta__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    max-width: 860px;
    margin: 0 auto;
    flex-wrap: wrap;
  }
  .page-faq-{{ section.id }} .faq-cta__text {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 600;
    color: #ffffff;
    margin: 0;
    line-height: 1.45;
  }
  .page-faq-{{ section.id }} .faq-cta__btn {
    display: inline-block;
    border: 2px solid #ffffff;
    color: #ffffff;
    padding: 1rem 2.2rem;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    font-family: inherit;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .page-faq-{{ section.id }} .faq-cta__btn:hover {
    background: #ffffff;
    color: #555;
  }
  @media screen and (max-width: 749px) {
    .page-faq-{{ section.id }} .faq-cta__inner {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="page-faq-{{ section.id }}">

  {%- comment -%}══ 1. HERO ══{%- endcomment -%}
  <div class="faq-hero">
    {%- if section.settings.hero_image != blank -%}
      {%- assign hero_alt = section.settings.hero_title | escape -%}
      {{ section.settings.hero_image | image_url: width: 1800 | image_tag:
        class: 'faq-hero__bg',
        alt: hero_alt,
        loading: 'eager',
        widths: '750, 1200, 1800'
      }}
    {%- endif -%}
    <div class="faq-hero__overlay"></div>
    <div class="faq-hero__content">
      <h1 class="faq-hero__title">{{ section.settings.hero_title }}</h1>
      {%- if section.settings.hero_subtitle != blank -%}
        <p class="faq-hero__subtitle">{{ section.settings.hero_subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}══ 2. MAIN FAQ ══{%- endcomment -%}
  <div class="faq-main">
    <div class="faq-main__inner">

      {%- comment -%} SIDEBAR {%- endcomment -%}
      <aside class="faq-sidebar">
        <h2 class="faq-sidebar__title">{{ section.settings.sidebar_title }}</h2>
        {%- if section.settings.sidebar_icon != blank -%}
          {{ section.settings.sidebar_icon | image_url: width: 104 | image_tag:
            class: 'faq-sidebar__icon',
            alt: '',
            loading: 'lazy'
          }}
        {%- endif -%}
        {%- if section.settings.sidebar_tagline != blank -%}
          <p class="faq-sidebar__tagline">{{ section.settings.sidebar_tagline }}</p>
        {%- endif -%}
        <div class="faq-sidebar__divider"></div>
        {%- if section.settings.sidebar_sub != blank -%}
          <p class="faq-sidebar__sub">{{ section.settings.sidebar_sub | newline_to_br }}</p>
        {%- endif -%}

        <div class="faq-search">
          <span class="faq-search__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <input
            id="faq-search-{{ section.id }}"
            class="faq-search__input"
            type="text"
            placeholder="{{ section.settings.search_placeholder }}"
            aria-label="{{ section.settings.search_placeholder }}"
          >
        </div>

        <div class="faq-help">
          {%- if section.settings.help_icon != blank -%}
            {{ section.settings.help_icon | image_url: width: 72 | image_tag:
              class: 'faq-help__icon',
              alt: '',
              loading: 'lazy'
            }}
          {%- endif -%}
          <div>
            <p class="faq-help__label">{{ section.settings.help_label }}</p>
            <p class="faq-help__desc">{{ section.settings.help_desc }}</p>
            <a href="{{ section.settings.contact_url }}" class="faq-help__link">{{ section.settings.contact_label }} →</a>
          </div>
        </div>
      </aside>

      {%- comment -%} PANEL ACCORDÉON {%- endcomment -%}
      <div class="faq-panel" id="faq-panel-{{ section.id }}">
        {%- assign category_open = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- if category_open -%}</div>{%- endif -%}
            <div class="faq-cat" {{ block.shopify_attributes }}>
              <div class="faq-cat__header">
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 56 | image_tag:
                    class: 'faq-cat__icon',
                    alt: '',
                    loading: 'lazy'
                  }}
                {%- endif -%}
                <h3 class="faq-cat__name" style="color: {{ block.settings.color }};">{{ block.settings.name }}</h3>
              </div>
            {%- assign category_open = true -%}
          {%- elsif block.type == 'faq_item' -%}
            <details class="faq-item" {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.question }}</span>
                <span class="faq-item__arrow" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="faq-item__body">{{ block.settings.answer | newline_to_br }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
        {%- if category_open -%}</div>{%- endif -%}

        <div class="faq-no-results" id="faq-no-results-{{ section.id }}">Aucun résultat pour votre recherche.</div>

        {%- if section.settings.panel_footer_text != blank -%}
          <div class="faq-panel__footer" id="faq-footer-{{ section.id }}">
            {{ section.settings.panel_footer_text }}
            {%- if section.settings.panel_footer_link != blank -%}
              <a href="{{ section.settings.contact_url }}" class="faq-panel__footer-link">{{ section.settings.panel_footer_link }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- comment -%}══ 3. CTA ══{%- endcomment -%}
  <div class="faq-cta" style="background-color: {{ section.settings.cta_bg_color }};">
    <div class="faq-cta__inner">
      {%- if section.settings.cta_text != blank -%}
        <p class="faq-cta__text">{{ section.settings.cta_text | newline_to_br }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="faq-cta__btn">{{ section.settings.cta_label }} →</a>
      {%- endif -%}
    </div>
  </div>

</div>

<script>
(function() {
  var input = document.getElementById('faq-search-{{ section.id }}');
  var panel = document.getElementById('faq-panel-{{ section.id }}');
  var noResults = document.getElementById('faq-no-results-{{ section.id }}');
  var footer = document.getElementById('faq-footer-{{ section.id }}');
  if (!input || !panel) return;
  input.addEventListener('input', function() {
    var query = this.value.toLowerCase().trim();
    var cats = panel.querySelectorAll('.faq-cat');
    var totalVisible = 0;
    cats.forEach(function(cat) {
      var items = cat.querySelectorAll('.faq-item');
      var catVisible = 0;
      items.forEach(function(item) {
        var text = item.querySelector('summary span:first-child').textContent.toLowerCase();
        var match = !query || text.includes(query);
        item.style.display = match ? '' : 'none';
        if (match) catVisible++;
      });
      cat.style.display = (!query || catVisible > 0) ? '' : 'none';
      totalVisible += catVisible;
    });
    if (noResults) noResults.style.display = (query && totalVisible === 0) ? 'block' : 'none';
    if (footer) footer.style.display = (query && totalVisible === 0) ? 'none' : '';
  });
})();
</script>

{% schema %}
{
  "name": "FAQ — LD Global",
