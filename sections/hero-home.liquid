{%- style -%}
  .hero-home-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: 'Figtree', sans-serif;
    text-align: center;
  }

  /* ── Tagline ── */
  .hero-home__tagline {
    display: block;
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 0.8rem;
  }

  /* ── Titre ── */
  .hero-home__title {
    font-size: clamp(2rem, 6vw, 6.5rem);
    font-weight: 900;
    color: #1a1a1a;
    line-height: 1.05;
    margin: 0 0 1.2rem 0;
    letter-spacing: -0.01em;
  }

  /* ── Description ── */
  .hero-home__desc {
    font-size: clamp(1rem, 1.8vw, 1.4rem);
    color: #555;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2rem auto;
  }
  .hero-home__desc p { margin: 0; }

  /* ── Bouton CTA outline ── */
  .hero-home__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 2px solid #36881f;
    color: #36881f;
    background: transparent;
    text-decoration: none;
    padding: 0.95rem 2.2rem;
    border-radius: 4px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background-color 0.2s, color 0.2s;
    margin-bottom: 3rem;
  }
  .hero-home__cta:hover {
    background-color: #36881f;
    color: #ffffff;
  }

  /* ── Séparateur ── */
  .hero-home__sep {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin: 0 auto 2.5rem auto;
    max-width: 800px;
  }

  /* ── Grille catégories — desktop : flex ligne unique centrée ── */
  .hero-home__categories {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Item catégorie ── */
  .hero-home__cat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    cursor: pointer;
  }

  .hero-home__cat-circle {
    width: {{ section.settings.circle_size }}px;
    height: {{ section.settings.circle_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-home__cat-item:hover .hero-home__cat-circle {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
  }

  .hero-home__cat-circle img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  .hero-home__cat-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: #2a2a2a;
    text-align: center;
  }
  .hero-home__cat-item:hover .hero-home__cat-label {
    color: #36881f;
  }

  /* ── Tablette (750px – 989px) ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .hero-home-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.85 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.85 | round: 0 }}px;
    }
    .hero-home__categories {
      gap: 1.2rem 1.6rem;
    }
    .hero-home__cat-circle {
      width: {{ section.settings.circle_size | times: 0.88 | round: 0 }}px;
      height: {{ section.settings.circle_size | times: 0.88 | round: 0 }}px;
    }
    .hero-home__cat-circle img {
      width: {{ section.settings.icon_size | times: 0.88 | round: 0 }}px;
      height: {{ section.settings.icon_size | times: 0.88 | round: 0 }}px;
    }
    .hero-home__cat-label {
      font-size: 1rem;
    }
  }

  /* ── Mobile (< 750px) ── */
  @media screen and (max-width: 749px) {
    .hero-home-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
    }

    .hero-home__tagline {
      font-size: 0.85rem;
      letter-spacing: 0.14em;
      margin-bottom: 0.6rem;
    }

    .hero-home__title {
      font-size: clamp(1.9rem, 9vw, 2.8rem);
      margin-bottom: 1rem;
      line-height: 1.08;
    }

    .hero-home__desc {
      font-size: 1rem;
      margin-bottom: 1.6rem;
      max-width: 100%;
    }
    .hero-home__desc p {
      padding: 0 2.5rem;
    }

    .hero-home__cta {
      width: 55%;
      font-size: 0.95rem;
      padding: 0.85rem 1.2rem;
      margin-bottom: 2rem;
      letter-spacing: 0.06em;
    }

    .hero-home__sep {
      margin-bottom: 1.8rem;
    }

    /* Grille 3 colonnes sur mobile */
    .hero-home__categories {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem 0.8rem;
      justify-items: center;
    }

    .hero-home__cat-circle {
      width: {{ section.settings.circle_size | times: 0.72 | round: 0 }}px;
      height: {{ section.settings.circle_size | times: 0.72 | round: 0 }}px;
    }
    .hero-home__cat-circle img {
      width: {{ section.settings.icon_size | times: 0.72 | round: 0 }}px;
      height: {{ section.settings.icon_size | times: 0.72 | round: 0 }}px;
    }
    .hero-home__cat-label {
      font-size: 0.85rem;
      font-weight: 600;
    }
    .hero-home__cat-item {
      gap: 0.45rem;
      width: 100%;
    }
  }
{%- endstyle -%}

<div class="hero-home-{{ section.id }}">
  <div class="page-width">

    {%- if section.settings.tagline != blank -%}
      <span class="hero-home__tagline">{{ section.settings.tagline }}</span>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="hero-home__title">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="hero-home__desc">{{ section.settings.description }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="hero-home__cta">
        {{ section.settings.cta_label }} →
      </a>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <hr class="hero-home__sep">
      <ul class="hero-home__categories" role="list">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" class="hero-home__cat-item">
              <div class="hero-home__cat-circle" style="background-color: {{ block.settings.circle_color }};">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 120 | image_tag:
                    loading: 'lazy',
                    alt: block.settings.label | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              {%- if block.settings.label != blank -%}
                <span class="hero-home__cat-label">{{ block.settings.label }}</span>
              {%- endif -%}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Hero — Accueil",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Texte principal"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Accroche (petite ligne au-dessus)",
      "default": "Simplifiez votre cuisine au quotidien"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "LD GLOBAL CO."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Des accessoires de cuisine pratiques pour gagner du temps au quotidien. Découvrez une sélection d'éplucheurs, spiraliseurs, minuteurs, outils de découpe, mixeurs et ustensiles pensés pour rendre la préparation plus simple, rapide et agréable.</p>"
    },
    {
      "type": "header",
      "content": "Bouton CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "Découvrir nos produits"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#f5f3ee"
    },
    {
      "type": "header",
      "content": "Icônes des catégories"
    },
    {
      "type": "range",
      "id": "circle_size",
      "min": 60,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Taille du cercle",
      "default": 90
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Taille de l'icône",
      "default": 55
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement haut",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement bas",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icône"
        },
        {
          "type": "paragraph",
          "content": "📐 Recommandé : 200 × 200 px (carré, PNG fond transparent)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Nom de la catégorie",
          "default": "Catégorie"
        },
        {
          "type": "color",
          "id": "circle_color",
          "label": "Couleur du cercle",
          "default": "#e8f5d0"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien de la catégorie"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero — Accueil",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "label": "Éplucheurs",
            "circle_color": "#d8f0d0"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Spiralisateurs",
            "circle_color": "#e8d8f5"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Minuteurs",
            "circle_color": "#d0e8f5"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Découpe",
            "circle_color": "#fde8c8"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Mixeurs",
            "circle_color": "#d0f0e8"
          }
        },
        {
          "type": "category",
          "settings": {
            "label": "Ustensiles",
            "circle_color": "#fcd8d8"
          }
        }
      ]
    }
  ]
}
{% endschema %}
