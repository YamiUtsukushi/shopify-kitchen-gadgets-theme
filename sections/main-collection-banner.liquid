{%- style -%}
  .collection-banner-{{ section.id }} {
    background-color: #fdfdfd;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    border-bottom: 1px solid #eeeeee;
  }

  @media screen and (max-width: 749px) {
    .collection-banner-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

  /* Fil d'Ariane */
  .collection-banner-{{ section.id }} .collection-banner__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: #888888;
    margin-bottom: 1rem;
  }
  .collection-banner-{{ section.id }} .collection-banner__breadcrumb a {
    color: #888888;
    text-decoration: none;
    transition: color 0.2s;
  }
  .collection-banner-{{ section.id }} .collection-banner__breadcrumb a:hover {
    color: #74B734;
  }
  .collection-banner-{{ section.id }} .collection-banner__breadcrumb .sep {
    color: #cccccc;
  }

  /* Titre */
  .collection-banner-{{ section.id }} .collection-banner__title {
    font-size: 2.6rem;
    font-weight: 800;
    color: #2a2a2a;
    margin: 0 0 1rem 0;
    line-height: 1.1;
  }

  @media screen and (max-width: 749px) {
    .collection-banner-{{ section.id }} .collection-banner__title {
      font-size: 1.8rem;
    }
  }

  /* Sous-titre */
  .collection-banner-{{ section.id }} .collection-banner__subtitle {
    color: #666666;
    font-size: 1rem;
    line-height: 1.75;
    max-width: 640px;
    margin: 0;
  }
  .collection-banner-{{ section.id }} .collection-banner__subtitle p {
    margin: 0;
  }
{%- endstyle -%}

<div class="collection-banner-{{ section.id }}">
  <div class="page-width">

    {%- comment -%} Fil d'Ariane {%- endcomment -%}
    <nav class="collection-banner__breadcrumb" aria-label="Fil d'Ariane">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="sep" aria-hidden="true">/</span>
      <span>{{ collection.title | default: 'Catalogue' }}</span>
    </nav>

    {%- comment -%} Titre {%- endcomment -%}
    <h1 class="collection-banner__title">
      {%- if section.settings.custom_title != blank -%}
        {{ section.settings.custom_title }}
      {%- else -%}
        {{ collection.title | default: 'Tous les produits' }}
      {%- endif -%}
    </h1>

    {%- comment -%} Sous-titre {%- endcomment -%}
    {%- if section.settings.subtitle != blank -%}
      <div class="collection-banner__subtitle rte">
        {{ section.settings.subtitle }}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "En-tête de catalogue",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "custom_title",
      "label": "Titre personnalisé",
      "info": "Laisse vide pour utiliser le nom de la collection",
      "default": "Tous les produits"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "<p>Découvrez notre sélection de gadgets de cuisine malins, simples à utiliser et accessibles à moins de 20 €. Des produits testés et approuvés pour simplifier votre quotidien. Livraison rapide, retours faciles.</p>"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacement haut",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espacement bas",
      "default": 40
    }
  ]
}
{% endschema %}
