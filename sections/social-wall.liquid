{%- style -%}
  .social-wall-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: 'Figtree', sans-serif;
  }

  @media screen and (max-width: 749px) {
    .social-wall-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

  /* ── En-tête ── */
  .social-wall__header {
    text-align: center;
    margin-bottom: 1.8rem;
  }
  .social-wall__title {
    font-size: clamp(2rem, 4vw, 6rem);
    font-weight: 900;
    color: #ffffff;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.01em;
  }
  .social-wall__subtitle {
    font-size: 2rem;
    color: #ffffff;
    margin: 0 0 0.6rem 0;
  }
  .social-wall__networks {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 1rem;
    color: #888;
  }
  .social-wall__network-link {
    color: #888;
    text-decoration: none;
    transition: color 0.2s;
  }
  .social-wall__network-link:hover { color: #36881f; }
  .social-wall__network-sep { color: #ccc; }

  /* ── Grille principale ── */
  .social-wall__grid {
    display: grid;
    grid-template-areas:
      "a b c"
      "d b e"
      "d f e";
    grid-template-columns: 1fr 1.5fr 1fr;
    grid-template-rows: 2fr 1.5fr 1.5fr;
    gap: 0.5rem;
    height: 640px;
  }

  /* ── Assignation des blocs ── */
  .social-wall__block:nth-child(1) { grid-area: a; }
  .social-wall__block:nth-child(2) { grid-area: b; }
  .social-wall__block:nth-child(3) { grid-area: c; }
  .social-wall__block:nth-child(4) { grid-area: d; }
  .social-wall__block:nth-child(5) { grid-area: f; }
  .social-wall__block:nth-child(6) { grid-area: e; }

  /* ── Bloc individuel ── */
  .social-wall__block {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    background-color: #2a2a2a;
  }
  .social-wall__block-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }
  .social-wall__block:hover .social-wall__block-bg {
    transform: scale(1.05);
  }
  .social-wall__block-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.08) 65%);
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .social-wall__block:hover .social-wall__block-overlay {
    opacity: 0.85;
  }

  /* ── Contenu texte ── */
  .social-wall__block-link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding: 1.2rem;
    height: 100%;
    text-decoration: none;
    box-sizing: border-box;
  }
  .social-wall__block-icon {
    width: 24px;
    height: 24px;
    color: #ffffff;
    flex-shrink: 0;
    margin-bottom: 0.1rem;
  }
  .social-wall__block:nth-child(2) .social-wall__block-icon {
    width: 30px;
    height: 30px;
  }
  .social-wall__block-title {
    margin: 0;
    font-weight: 800;
    line-height: 1.25;
    text-shadow: 0 1px 6px rgba(0,0,0,0.35);
  }
  .social-wall__block-desc {
    margin: 0;
    line-height: 1.45;
  }

  /* ── Tablette (750px – 989px) ── */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .social-wall__grid {
      grid-template-areas:
        "a b"
        "c d"
        "e f";
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 220px 185px 185px;
      height: auto;
    }
    .social-wall__block:nth-child(1) { grid-area: a; }
    .social-wall__block:nth-child(2) { grid-area: b; }
    .social-wall__block:nth-child(3) { grid-area: c; }
    .social-wall__block:nth-child(4) { grid-area: d; }
    .social-wall__block:nth-child(5) { grid-area: e; }
    .social-wall__block:nth-child(6) { grid-area: f; }

    .social-wall__title    { font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
    .social-wall__subtitle { font-size: 1.05rem; }

    /* Textes des blocs — override des inline styles */
    .social-wall__block-title { font-size: clamp(1.05rem, 2vw, 1.3rem) !important; }
    .social-wall__block-desc  { font-size: clamp(0.9rem, 1.5vw, 1.05rem) !important; }
    .social-wall__block-link  { gap: 0.8rem; }
  }

  /* ── Mobile (< 750px) ── */
  @media screen and (max-width: 749px) {
    .social-wall-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 | round: 0 }}px;
    }

    /* En-tête */
    .social-wall__header   { margin-bottom: 1.2rem; }
    .social-wall__title    { font-size: clamp(1.5rem, 7vw, 2rem); }
    .social-wall__subtitle { font-size: 0.95rem; }

    /* Grille : blocs 1+2 pleine largeur, 3+4 côte à côte, 5+6 côte à côte */
    .social-wall__grid {
      grid-template-areas:
        "a a"
        "b b"
        "c d"
        "e f";
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 170px 185px 130px 130px;
      height: auto;
      gap: 0.4rem;
    }
    .social-wall__block:nth-child(1) { grid-area: a; }
    .social-wall__block:nth-child(2) { grid-area: b; }
    .social-wall__block:nth-child(3) { grid-area: c; }
    .social-wall__block:nth-child(4) { grid-area: d; }
    .social-wall__block:nth-child(5) { grid-area: e; }
    .social-wall__block:nth-child(6) { grid-area: f; }

    /* Contenu intérieur */
    .social-wall__block-link {
      padding: 0.8rem;
      gap: 0.8rem;
    }
    .social-wall__block-icon {
      width: 18px !important;
      height: 18px !important;
    }

    /* Blocs petits (côte à côte) */
    .social-wall__block:nth-child(3) .social-wall__block-title,
    .social-wall__block:nth-child(4) .social-wall__block-title,
    .social-wall__block:nth-child(5) .social-wall__block-title,
    .social-wall__block:nth-child(6) .social-wall__block-title {
      font-size: clamp(0.92rem, 3.5vw, 1.08rem) !important;
      -webkit-line-clamp: 3;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .social-wall__block:nth-child(3) .social-wall__block-desc,
    .social-wall__block:nth-child(4) .social-wall__block-desc,
    .social-wall__block:nth-child(5) .social-wall__block-desc,
    .social-wall__block:nth-child(6) .social-wall__block-desc {
      display: none;
    }

    /* Blocs pleine largeur */
    .social-wall__block:nth-child(1) .social-wall__block-title,
    .social-wall__block:nth-child(2) .social-wall__block-title {
      font-size: clamp(1.1rem, 5vw, 1.4rem) !important;
    }
    .social-wall__block:nth-child(1) .social-wall__block-desc,
    .social-wall__block:nth-child(2) .social-wall__block-desc {
      font-size: clamp(0.88rem, 3.5vw, 1rem) !important;
    }
  }
{%- endstyle -%}

