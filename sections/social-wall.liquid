<div class="social-wall-{{ section.id }}">
  <div class="page-width">

    {%- comment -%} ── En-tête ── {%- endcomment -%}
    <div class="social-wall__header">
      {%- if section.settings.title != blank -%}
        <h2 class="social-wall__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="social-wall__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.instagram_url != blank or section.settings.tiktok_url != blank or section.settings.facebook_url != blank or section.settings.pinterest_url != blank -%}
        <div class="social-wall__networks">
          {%- assign sep = false -%}
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="social-wall__network-link" target="_blank" rel="noopener">Instagram</a>
            {%- assign sep = true -%}
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            {%- if sep -%}<span class="social-wall__network-sep">•</span>{%- endif -%}
            <a href="{{ section.settings.tiktok_url }}" class="social-wall__network-link" target="_blank" rel="noopener">TikTok</a>
            {%- assign sep = true -%}
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            {%- if sep -%}<span class="social-wall__network-sep">•</span>{%- endif -%}
            <a href="{{ section.settings.facebook_url }}" class="social-wall__network-link" target="_blank" rel="noopener">Facebook</a>
            {%- assign sep = true -%}
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            {%- if sep -%}<span class="social-wall__network-sep">•</span>{%- endif -%}
            <a href="{{ section.settings.pinterest_url }}" class="social-wall__network-link" target="_blank" rel="noopener">Pinterest</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── Grille 6 blocs ── {%- endcomment -%}
    <div class="social-wall__grid">
      {%- for block in section.blocks -%}
        <div class="social-wall__block" {{ block.shopify_attributes }}>

          {%- if block.settings.image != blank -%}
            {%- assign block_alt = block.settings.title | escape -%}
            {{ block.settings.image | image_url: width: 900 | image_tag:
              class: 'social-wall__block-bg',
              alt: block_alt,
              loading: 'lazy',
              widths: '400, 600, 900'
            }}
          {%- endif -%}

          <div class="social-wall__block-overlay"></div>

          <a href="{{ block.settings.link | default: '#' }}" class="social-wall__block-link" aria-label="{{ block.settings.title | escape }}">

            {%- if block.settings.custom_icon != blank -%}
              {{ block.settings.custom_icon | image_url: width: 60 | image_tag:
                class: 'social-wall__block-icon',
                alt: block.settings.social_network,
                loading: 'lazy'
              }}
            {%- else -%}
              {%- case block.settings.social_network -%}
                {%- when 'instagram' -%}{{ svg_instagram }}
                {%- when 'tiktok' -%}{{ svg_tiktok }}
                {%- when 'facebook' -%}{{ svg_facebook }}
                {%- when 'pinterest' -%}{{ svg_pinterest }}
              {%- endcase -%}
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class="social-wall__block-title" style="font-size: {{ block.settings.title_size }}px; color: {{ block.settings.title_color }};">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="social-wall__block-desc" style="font-size: {{ block.settings.desc_size }}px; color: {{ block.settings.desc_color }};">{{ block.settings.description }}</p>
            {%- endif -%}

          </a>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

